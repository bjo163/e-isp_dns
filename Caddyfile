# =============================================================================
# TrustPositif — Caddyfile  (single-domain, host-network mode)
#
# All services run on the host network (required for LXC containers).
# One domain serves both the block page and the admin API via path routing:
#   /api/*, /myip, /metrics, /health  → Go backend (localhost:8080)
#   everything else                    → Next.js    (localhost:3000)
#
# HTTP :80 catch-all handles blocked-domain intercept (localhost:8081).
#
# Required env vars: DOMAIN, ACME_EMAIL
# =============================================================================

{
	email {$ACME_EMAIL}
	# Uncomment while testing to avoid Let's Encrypt rate limits:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# ── HTTP catch-all (:80) ──────────────────────────────────────────────────────
# Known domain → 301 HTTPS; every other Host → Go intercept (blocked redirect).
:80 {
	@known host {$DOMAIN}
	redir @known https://{host}{uri} 301

	# Subscriber browser arrives here because DNS returned our IP for the
	# blocked site. Go intercept reads Host header → 302 to block page.
	reverse_proxy 127.0.0.1:8081 {
		header_up X-Real-IP {remote_host}
	}
}

# ── Main site (single domain — block page + admin API) ───────────────────────
{$DOMAIN} {
	# Go API routes → Fiber :8080
	handle /api/* {
		reverse_proxy 127.0.0.1:8080 {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /myip {
		reverse_proxy 127.0.0.1:8080 {
			header_up X-Real-IP {remote_host}
		}
	}
	handle /metrics {
		reverse_proxy 127.0.0.1:8080
	}
	handle /health {
		reverse_proxy 127.0.0.1:8080
	}

	# Everything else → Next.js :3000
	handle {
		reverse_proxy 127.0.0.1:3000 {
			header_up X-Real-IP {remote_host}
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
	}

	encode gzip
	log
}
