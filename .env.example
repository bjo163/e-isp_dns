# =============================================================================
# TrustPositif — Environment Variables
# Copy this file to .env and edit before running: docker compose up -d --build
# =============================================================================

# ── Domains & TLS (Caddy / Let's Encrypt) ───────────────────────────────────
# The domain subscribers see when they visit a blocked site.
DOMAIN=block.example.com

# The domain used to reach the admin REST API from a browser.
API_DOMAIN=api.example.com

# Contact email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# ── Next.js ──────────────────────────────────────────────────────────────────
# Full public URL of the admin API — baked into the JS bundle at build time.
# Must be browser-accessible (not the internal Docker hostname).
API_URL=https://api.example.com

# ── Security ─────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens for admin authentication.
# ⚠  CHANGE THIS to a long random string in production!
#    e.g.: openssl rand -base64 48
JWT_SECRET=trustpositif-secret-change-in-prod

# ── Redis ────────────────────────────────────────────────────────────────────
# Connection URL for the L2 cache (auto-set in docker-compose; override for
# external Redis). Leave empty to run L1-only (single instance mode).
# REDIS_URL=redis://redis:6379/0
