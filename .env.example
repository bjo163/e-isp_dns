# =============================================================================
# TrustPositif — environment variables
# Copy this file to .env and edit before running docker compose up
# =============================================================================

# ── Domains (Caddy / Let's Encrypt) ─────────────────────────────────────────
# The domain subscribers see when they visit a blocked site.
DOMAIN=block.example.com

# The domain used to reach the admin REST API from a browser.
API_DOMAIN=api.example.com

# Your email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@example.com

# ── Next.js build arg ────────────────────────────────────────────────────────
# Full HTTPS URL of the admin API, baked into the JS bundle at build time.
# Must be browser-accessible (not the internal Docker hostname).
API_URL=https://api.example.com
