# =============================================================================
# TrustPositif — Environment Variables
# Copy this file to .env and edit before running: docker compose up -d --build
# =============================================================================

# ── Domain & TLS (Caddy / Let's Encrypt) ────────────────────────────────────
# Single domain for block page + admin panel + API (path-based routing).
DOMAIN=jahanam.mycocolink.com

# Contact email for Let's Encrypt certificate notifications.
ACME_EMAIL=admin@mycocolink.com

# ── Next.js ──────────────────────────────────────────────────────────────────
# In production the web container uses relative URLs (same-origin via Caddy).
# No NEXT_PUBLIC_API_URL needed here — only set it in web/.env.local for
# local development (see web/.env.local.example).

# ── Block Page URL (Go intercept redirect) ───────────────────────────────────
# Where blocked subscribers are redirected. Must be the public HTTPS URL.
BLOCK_PAGE_URL=https://jahanam.mycocolink.com

# ── Security ─────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens for admin authentication.
# ⚠  CHANGE THIS to a long random string in production!
#    e.g.: openssl rand -base64 48
JWT_SECRET=trustpositif-secret-change-in-prod

# ── Redis ────────────────────────────────────────────────────────────────────
# Auto-set in docker-compose to redis://127.0.0.1:6379/0 (host network mode).
# Override only if using an external Redis instance.
# REDIS_URL=redis://127.0.0.1:6379/0
